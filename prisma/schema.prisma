generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  description  String?
  category     String   @default("premium")
  tags         String[]
  variants     Json
  stock        Int?
  imageUrl     String?
  mediaType    String?
  emoji        String   @default("🌿")
  badge        String?
  origin       String?
  sortOrder    Int      @default(99)
  isOnSale     Boolean  @default(false)
  isComingSoon Boolean  @default(false)
  hidden       Boolean  @default(false)
  shipFrom     String   @default("spain")
  bundleItems  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Order {
  id         String   @id
  userId     String
  status     String   @default("pending")
  total      Float
  items      Json
  note       String?
  tracking   String?
  referredBy String?
  createdAt  DateTime @default(now())
}

model Affiliate {
  id               String    @id @default(cuid())
  username         String    @unique
  code             String    @unique
  referredBy       String?
  referredAt       DateTime?
  joinedAt         DateTime  @default(now())
  tier             String    @default("bronze")
  commissionRate   Float     @default(0.05)
  commissionEarned Float     @default(0)
  commissionPaid   Float     @default(0)
}

model CommissionPayout {
  id            String    @id @default(cuid())
  affiliateCode String
  username      String
  amount        Float
  status        String    @default("pending")
  method        String    @default("crypto")
  note          String?
  requestedAt   DateTime  @default(now())
  processedAt   DateTime?
}

model NewsFeed {
  id          String   @id @default(cuid())
  title       String
  content     String
  emoji       String   @default("📢")
  imageUrl    String?
  productLink String?
  createdAt   DateTime @default(now())
}

model ChannelMember {
  id       String   @id @default(cuid())
  userId   String   @unique
  handle   String
  name     String
  joinedAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  name      String
  handle    String   @unique
  hash      String
  role      String   @default("user")
  avatarUrl String?
  createdAt DateTime @default(now())
}

model UserActivity {
  id           String   @id @default(cuid())
  userId       String   @unique
  lastSeen     DateTime @default(now())
  loginCount   Int      @default(1)
  totalMinutes Int      @default(0)
}

model GameScore {
  id        String   @id @default(cuid())
  userId    String
  handle    String
  name      String
  score     Int
  month     String
  createdAt DateTime @default(now())
}

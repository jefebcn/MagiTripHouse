# === NEON DB ===
# Copia entrambe le stringhe dal dashboard Neon → Connection Details
DATABASE_URL="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# === NEXTAUTH ===
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-32-char-secret-here"
NEXTAUTH_URL="http://localhost:3000"   # cambia con il tuo dominio Vercel in produzione

# === ADMIN CREDENTIALS (ora sicure, non più nel codice client!) ===
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="scegli-una-password-sicura"

# === VERCEL BLOB (da Vercel Dashboard → Storage → Blob → Create Store) ===
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# === WEB PUSH VAPID KEYS ===
# Genera con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="BG..."
VAPID_PRIVATE_KEY="..."
VAPID_EMAIL="mailto:admin@example.com"
